{
  "redirects": [
    {
      "source": "/norway",
      "destination": "/norway/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/norway/",
      "destination": "https://hatchwatch-norway.vercel.app/"
    },
    {
      "source": "/norway/(.*)",
      "destination": "https://hatchwatch-norway.vercel.app/$1"
    }
  ]
}
